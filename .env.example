# TAK Manager — Environment Configuration
# Copy to .env and edit before deploying: cp .env.example .env

# ── Domain (single-host routing) ────────────────────────────────────────────

# Public domain for UI and API (API is path-routed at /api)
DOMAIN=data.opengeo.space

# ── Backend ────────────────────────────────────────────────────────────────

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS allowed origins — include the public app origin.
CORS_ORIGINS=["https://data.opengeo.space"]
