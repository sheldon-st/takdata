# TAK Manager — Environment Configuration
# Copy to .env and edit before deploying: cp .env.example .env

# ── Backend ────────────────────────────────────────────────────────────────

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS allowed origins (JSON array). With nginx proxying from the same domain,
# same-origin rules apply and this can stay as ["*"]. Tighten for production:
# CORS_ORIGINS=["https://your-domain.com"]
CORS_ORIGINS=["*"]

# ── Frontend ───────────────────────────────────────────────────────────────

# Host port that the frontend nginx container will bind to.
# Set to 80 for plain HTTP; see DEPLOY.md for SSL options.
HOST_PORT=80
