# TAK Manager — Environment Configuration
# Copy to .env and edit before deploying: cp .env.example .env

# ── Domains (used by caddy-docker-proxy labels) ────────────────────────────

# Domain for the frontend SPA
DOMAIN=data.opengeo.space

# Domain for the backend API (accessed cross-origin from the SPA)
API_DOMAIN=api.data.opengeo.space

# ── Backend ────────────────────────────────────────────────────────────────

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS allowed origins — must include the frontend domain since the SPA calls
# the API cross-origin (frontend is at DOMAIN, API is at API_DOMAIN).
CORS_ORIGINS=["https://data.opengeo.space"]
